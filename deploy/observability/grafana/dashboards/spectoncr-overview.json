{
  "uid": "spectoncr-overview",
  "title": "SpectonCR — Overview (Golden Signals)",
  "tags": ["spectoncr", "registry", "slo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(up{job=~\"spectoncr-.*\"}, job)",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Up",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      },
      "targets": [
        { "expr": "up{job=~\"$service\"}", "legendFormat": "{{job}}", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Build",
      "gridPos": { "h": 4, "w": 8, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name" },
      "targets": [
        { "expr": "spectoncr_build_info", "legendFormat": "{{service}} {{version}}", "refId": "A", "instant": true }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Process uptime",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "time() - spectoncr_process_start_time_seconds", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Requests / sec",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "sum(rate(spectoncr_http_requests_total[5m]))", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "5xx ratio (5m)",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.05 }] }
        }
      },
      "targets": [
        { "expr": "sum(rate(spectoncr_http_requests_total{status_class=\"5xx\"}[5m])) / clamp_min(sum(rate(spectoncr_http_requests_total[5m])), 1e-9)", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Request rate by route",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "sum by (route) (rate(spectoncr_http_requests_total[5m]))", "legendFormat": "{{route}}", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Status mix",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "stacking": { "mode": "normal" } } } },
      "targets": [
        { "expr": "sum by (status_class) (rate(spectoncr_http_requests_total[5m]))", "legendFormat": "{{status_class}}", "refId": "A" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(spectoncr_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(spectoncr_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(spectoncr_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "p99 latency by route",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum by (le, route) (rate(spectoncr_http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{route}}", "refId": "A" }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Push / pull throughput (bytes/sec)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        { "expr": "rate(registry_push_bytes_total[5m])", "legendFormat": "push", "refId": "A" },
        { "expr": "rate(registry_pull_bytes_total[5m])", "legendFormat": "pull", "refId": "B" }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "In-flight requests",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (route) (spectoncr_http_requests_in_flight)", "legendFormat": "{{route}}", "refId": "A" }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Rate-limit rejections by tenant",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "sum by (tenant) (rate(spectoncr_rate_limit_rejected_total[5m]))", "legendFormat": "{{tenant}}", "refId": "A" }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Push/pull operation rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "rate(registry_manifest_push_total[5m])", "legendFormat": "manifest push", "refId": "A" },
        { "expr": "rate(registry_manifest_pull_total[5m])", "legendFormat": "manifest pull", "refId": "B" },
        { "expr": "rate(registry_blob_pull_total[5m])", "legendFormat": "blob pull", "refId": "C" }
      ]
    }
  ]
}
