{
  "uid": "spectoncr-replication",
  "title": "SpectonCR — Multi-region Replication",
  "tags": ["spectoncr", "replication", "ha"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Queue depth",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 200 }, { "color": "red", "value": 800 }] }
        }
      },
      "targets": [
        { "expr": "spectoncr_replication_queue_depth", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Max replication lag",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "max(spectoncr_replication_lag_seconds)", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Replication failures (5m)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum(rate(spectoncr_replication_events_total{outcome!=\"success\"}[5m]))", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Healthy regions",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(spectoncr_region_healthy)", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Replication enqueued / sec by kind",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum by (kind) (rate(spectoncr_replication_enqueued_total[5m]))", "legendFormat": "{{kind}}", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Replication outcomes by region",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum by (region, outcome) (rate(spectoncr_replication_events_total[5m]))", "legendFormat": "{{region}} / {{outcome}}", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Replication lag by source region",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "spectoncr_replication_lag_seconds", "legendFormat": "{{source_region}}", "refId": "A" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "p95 replication event duration",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, region, kind) (rate(spectoncr_replication_event_duration_seconds_bucket[5m])))", "legendFormat": "{{region}} {{kind}}", "refId": "A" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Region health (1 = healthy)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "spectoncr_region_healthy", "legendFormat": "{{region}}", "refId": "A" }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Region health-check latency",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "spectoncr_region_health_check_latency_seconds", "legendFormat": "{{region}}", "refId": "A" }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Region health transitions",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum by (region, to) (rate(spectoncr_region_health_transitions_total[15m]))", "legendFormat": "{{region}} → {{to}}", "refId": "A" }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Replication bytes / sec by region",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        { "expr": "sum by (region) (rate(spectoncr_replication_bytes_total[5m]))", "legendFormat": "{{region}}", "refId": "A" }
      ]
    }
  ]
}
