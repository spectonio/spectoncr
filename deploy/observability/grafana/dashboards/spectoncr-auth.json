{
  "uid": "spectoncr-auth",
  "title": "SpectonCR — Auth & Identity",
  "tags": ["spectoncr", "auth", "oidc"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Tokens issued / sec",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum(rate(registry_token_issued_total[5m]))", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Auth failures / sec",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] }
        }
      },
      "targets": [
        { "expr": "sum(rate(registry_auth_failures_total[5m]))", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "OIDC logins / sec (success)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum(rate(registry_oidc_logins_total{status=\"success\"}[5m]))", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Token refreshes / sec",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum(rate(registry_token_refresh_total[5m]))", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Auth failures by reason",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "stacking": { "mode": "normal" } } } },
      "targets": [
        { "expr": "sum by (reason) (rate(registry_auth_failures_total[5m]))", "legendFormat": "{{reason}}", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "OIDC outcomes by provider",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum by (provider, status) (rate(registry_oidc_logins_total[5m]))", "legendFormat": "{{provider}} / {{status}}", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Auth route p95 latency",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, route) (rate(spectoncr_auth_http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{route}}", "refId": "A" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Auth request rate by route",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "sum by (route) (rate(spectoncr_auth_http_requests_total[5m]))", "legendFormat": "{{route}}", "refId": "A" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Robot account auths",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum by (robot) (rate(registry_robot_auth_total[5m]))", "legendFormat": "{{robot}}", "refId": "A" }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Group mapping hits",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum by (group) (rate(registry_group_mapping_hits_total[5m]))", "legendFormat": "{{group}}", "refId": "A" }
      ]
    }
  ]
}
