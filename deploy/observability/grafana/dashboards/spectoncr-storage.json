{
  "uid": "spectoncr-storage",
  "title": "SpectonCR — Storage Backend",
  "tags": ["spectoncr", "storage", "resilience"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Circuit breaker state",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" }, "1": { "text": "HALF-OPEN", "color": "yellow" }, "2": { "text": "OPEN", "color": "red" } } }
          ]
        }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "spectoncr_circuit_breaker_state", "legendFormat": "{{breaker}}", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Storage error rate (5m)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum(rate(spectoncr_storage_operation_errors_total[5m]))", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Retry exhaustions (5m)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum(rate(spectoncr_retry_attempts_total{outcome=\"exhausted\"}[5m]))", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "CB rejections (5m)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum(rate(spectoncr_circuit_breaker_rejections_total[5m]))", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Storage operations / sec by op",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum by (operation) (rate(spectoncr_storage_operations_total[5m]))", "legendFormat": "{{operation}}", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Storage error rate by op",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum by (operation) (rate(spectoncr_storage_operation_errors_total[5m]))", "legendFormat": "{{operation}}", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "p95 storage latency by op",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(spectoncr_storage_operation_duration_seconds_bucket[5m])))", "legendFormat": "{{operation}}", "refId": "A" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "p99 storage latency by op",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum by (le, operation) (rate(spectoncr_storage_operation_duration_seconds_bucket[5m])))", "legendFormat": "{{operation}}", "refId": "A" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Retry attempts (recovered vs exhausted)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum by (operation) (rate(spectoncr_retry_attempts_total{outcome=\"recovered\"}[5m]))", "legendFormat": "{{operation}} recovered", "refId": "A" },
        { "expr": "sum by (operation) (rate(spectoncr_retry_attempts_total{outcome=\"exhausted\"}[5m]))", "legendFormat": "{{operation}} exhausted", "refId": "B" }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Circuit breaker transitions",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum by (breaker, to) (rate(spectoncr_circuit_breaker_transitions_total[5m]))", "legendFormat": "{{breaker}} → {{to}}", "refId": "A" }
      ]
    }
  ]
}
