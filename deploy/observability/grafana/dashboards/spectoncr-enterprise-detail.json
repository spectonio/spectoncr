        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "SpectonCR — Operations Detail",
  "uid": "spectoncr-enterprise-detail",
  "version": 1,
  "weekStart": ""
}
